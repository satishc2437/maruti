{
  "schemaVersion": 1,
  "base": "repo",
  "fs": {
    "read": {
      "allow": [
        "README.md",
        "CLAUDE.md",
        "docs/**",
        "pyproject.toml",
        "mcp-tools/**",
        "agents/**"
      ],
      "deny": []
    },
    "readWrite": {
      "allow": [
        "mcp-tools/*/specs/product-docs/**"
      ],
      "deny": []
    }
  },
  "semantics": {
    "denyOverridesAllow": true,
    "readWriteImpliesRead": true,
    "patternsAreRepoRelative": true,
    "unknownTopLevelKeys": "ignore"
  }
}
