# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/

# Build / dist / packaging
build/
dist/
*.egg-info/
.eggs/
src/*.egg-info/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# IDE / editor
.idea/

# Claude Code: only local/machine-specific state is ignored. The
# .claude/agents/, .claude/skills/, and .claude/commands/ trees are
# symlink mirrors managed by scripts/link_packages.py and ARE tracked.
.claude/settings.local.json
.claude/projects/

# uv / pip
.uv/
uv.lock

# Logs / temp
*.log
tmp/
.cache/

# Environment files
.env*

# Project-specific
agent-memory/.mypy_cache/
agent-memory/.pytest_cache/
agent-memory/__pycache__/
agent-memory/src/agent_memory/__pycache__/

# OS / editor / temp (universal)
.DS_Store
Thumbs.db
*.swp
*.tmp

# Common Python tooling caches
.mypy_cache/
.ruff_cache/
